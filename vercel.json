{
  "version": 2,
  "buildCommand": "echo 'No build'",
  "outputDirectory": "public",
  "env": {
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_SERVICES_CACHE": "/tmp/services.php"
  },
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "rewrites": [
    {
      "handle": "filesystem"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
