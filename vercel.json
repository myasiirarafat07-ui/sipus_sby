{
  "version": 2,
  "outputDirectory": "public",
  "env": {
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_SERVICES_CACHE": "/tmp/services.php"
  },
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/build/$1"
    },
    {
      "src": "/(favicon\\.ico|robots\\.txt)",
      "dest": "/$1"
    },
    {
      "src": "/(images|css|js)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
