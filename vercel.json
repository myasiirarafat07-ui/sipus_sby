{
  "version": 2,
  "framework": null,
  "env": {
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_SERVICES_CACHE": "/tmp/services.php"
  },
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "rewrites": [
    {
      "source": "/build/(.*)",
      "destination": "/public/build/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/public/favicon.ico"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
